generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  telegramId       BigInt   @unique
  language         String   @default("zh-CN")
  polymarketAddress String?
  safeAddress      String?
  funderAddress    String?
  isBanned         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  bindCodes        BindCode[]
  tradeOrders      TradeOrder[]
}

model BindCode {
  id         String   @id @default(cuid())
  code       String   @unique
  telegramId BigInt
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [telegramId], references: [telegramId], onDelete: Cascade)
}

model TradeOrder {
  id           String   @id @default(cuid())
  telegramId   BigInt
  marketId     String
  outcomeIndex Int
  side         String
  amount       Float
  status       String   @default("PENDING")
  orderId      String?
  avgPrice     Float?
  txHash       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [telegramId], references: [telegramId], onDelete: Cascade)

  @@index([telegramId, createdAt])
  @@index([marketId, outcomeIndex])
}

model PriceAlert {
  id           String   @id @default(cuid())
  telegramId   BigInt
  marketId     String
  outcomeIndex Int
  condition    String   // ABOVE, BELOW
  targetPrice  Float
  isActive     Boolean  @default(true)
  triggeredAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [telegramId], references: [telegramId], onDelete: Cascade)

  @@index([telegramId, isActive])
  @@index([marketId, isActive])
}

model CopyTradeSignal {
  id          String   @id @default(cuid())
  marketId    String
  outcomeIndex Int
  side        String
  amount      Float
  description String?
  isActive    Boolean  @default(true)
  executedCount Int    @default(0)
  createdBy   String   // admin who created
  createdAt   DateTime @default(now())
  executedAt  DateTime?

  @@index([isActive, createdAt])
}

model CopyTradeConfig {
  id            String   @id @default(cuid())
  telegramId    BigInt
  ratio         Float    @default(1.0)     // 跟单比例
  maxAmount     Float    @default(100)     // 最大单笔金额
  isActive      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [telegramId], references: [telegramId], onDelete: Cascade)

  @@unique([telegramId])
  @@index([isActive])
}

