# Core
NODE_ENV=development

# Database / Cache
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cryptopulse
REDIS_URL=redis://localhost:6379

# Telegram
TELEGRAM_BOT_TOKEN=
BOT_API_TOKEN=
TELEGRAM_TEST_GROUP_ID=
API_BASE_URL=http://localhost:3000
WEB_BASE_URL=http://localhost:3000

# Admin (single-admin)
ADMIN_TOKEN=

# Polymarket
POLYMARKET_CHAIN_ID=137
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com
POLYMARKET_RELAYER_URL=https://relayer-v2.polymarket.com/
POLYMARKET_RPC_URL=

# Builder (server-side only; never expose to client)
POLY_BUILDER_API_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=

# Builder signing (remote signing endpoint auth)
SIGNING_TOKEN=

# Wallet onboarding (pick one; embed wallet preferred)
# Privy (preferred): from privy.io dashboard
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Magic Link (fallback)
MAGIC_PUBLISHABLE_KEY=
MAGIC_SECRET_KEY=

# Observability (optional)
SENTRY_DSN=
